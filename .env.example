# Department Head status upload enforcement templates (numeric)
BREVO_STATUS_UPLOAD_REMINDER_TEMPLATE_ID=
BREVO_STATUS_UPLOAD_SUSPENDED_TEMPLATE_ID=
NODE_ENV=development
APP_NAME="Academic Project Platform and Collaboration System"
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
PORT=3001
API_PREFIX=api
API_VERSION=v1
LOG_LEVEL=info

# ====================================
# DATABASE CONFIGURATION 
# ====================================
DATABASE_URL="postgresql://postgres:belight4others@localhost:5432/Academia?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:belight4others@localhost:5432/Academia_shadow?schema=public"
DATABASE_SSL=false

# ====================================
# PLATFORM ADMIN (SYSTEM TENANT)
# ====================================
# Used by the seed scripts (e.g. `npm run seed:admin`) to create/update the system tenant's
# Platform Admin account.
PLATFORM_ADMIN_EMAIL=admin@academia.et
PLATFORM_ADMIN_PASSWORD=change-me

# ====================================
# AUTHENTICATION & SECURITY 
# ====================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# Optional pepper used to hash short-lived password reset OTPs (recommended in production)
PASSWORD_RESET_OTP_PEPPER=

# ====================================
# SUBSCRIPTION & PAYMENTS (PADDLE)
# ====================================
PADDLE_API_KEY=your-paddle-api-key
PADDLE_PUBLIC_KEY=your-paddle-public-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_ENVIRONMENT=sandbox

# ====================================
# FILE STORAGE (CLOUDINARY)
# ====================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,pptx,jpg,png

# ====================================
# EMAIL SERVICE (BREVO/SENDINBLUE)
# ====================================
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@academic-platform.com
EMAIL_FROM_NAME="Academic Project Platform"
# Primary mailbox used for system/support/admin notifications
EMAIL_SUPPORT=support@academia.et
EMAIL_LOGO_URL=https://academia.et/favicon.png
EMAIL_DEFAULT_AVATAR_URL=
INVITATION_EXPIRY_DAYS=7
EMAIL_TEMPLATES_PATH=./email-templates

# Brevo Transactional Template IDs (numeric)
BREVO_PASSWORD_RESET_OTP_TEMPLATE_ID=
BREVO_EMAIL_VERIFICATION_OTP_TEMPLATE_ID=
BREVO_INVITATION_TEMPLATE_ID=
BREVO_STUDENT_PROFILE_COMPLETION_REMINDER_TEMPLATE_ID=51

# Group leader request templates (numeric)
BREVO_GROUP_LEADER_REQUEST_SUBMITTED_TEMPLATE_ID=
BREVO_GROUP_LEADER_REQUEST_APPROVED_TEMPLATE_ID=
BREVO_GROUP_LEADER_REQUEST_REJECTED_TEMPLATE_ID=

# Project group invitation template (numeric)
BREVO_PROJECT_GROUP_INVITATION_TEMPLATE_ID=

# Institution verification templates (numeric)
BREVO_INSTITUTION_VERIFICATION_SUBMITTED_ADMIN_TEMPLATE_ID=
BREVO_INSTITUTION_VERIFICATION_RECEIVED_DEPTHEAD_TEMPLATE_ID=
BREVO_INSTITUTION_VERIFICATION_APPROVED_TEMPLATE_ID=
BREVO_INSTITUTION_VERIFICATION_REJECTED_TEMPLATE_ID=

# Institution verification (numeric)
# - Submitted email (to EMAIL_SUPPORT)
BREVO_INSTITUTION_VERIFICATION_SUBMITTED_ADMIN_TEMPLATE_ID=
# - Received email (to Department Head)
BREVO_INSTITUTION_VERIFICATION_RECEIVED_DEPTHEAD_TEMPLATE_ID=
# - Approved email (to Department Head)
BREVO_INSTITUTION_VERIFICATION_APPROVED_TEMPLATE_ID=
# - Rejected email (to Department Head)
BREVO_INSTITUTION_VERIFICATION_REJECTED_TEMPLATE_ID=

# Optional contact templates (numeric)
BREVO_CONTACT_TEMPLATE_ID=
BREVO_CONTACT_ACK_TEMPLATE_ID=

# ====================================
# CACHING & QUEUE (REDIS)
# ====================================
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600
REDIS_PREFIX=academic_platform

# ====================================
# WEB PUSH (VAPID) - OPTIONAL
# ====================================
# Only required if you want browser push notifications to work when the tab is closed.
# Generate keys (example): npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:support@academia.et
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ====================================
# RATE LIMITING
# ====================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ====================================
# PADDLE BILLING INTEGRATION
# ====================================
# Get these from https://sandbox-vendors.paddle.com/ (for testing) or https://vendors.paddle.com/ (production)
# 1. API Key: Go to Developer Tools > Authentication > API Keys
# 2. Webhook Secret: Go to Developer Tools > Webhooks > Webhook Secret
# 3. Environment: 'sandbox' for testing, 'production' for live
PADDLE_API_KEY=pdl_sdbx_apikey_01khs1hrev8cfradycs3nf495t_dXDzSc8NVQcpCRjvgXDTDk_AVV
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret-here
PADDLE_ENVIRONMENT=sandbox
