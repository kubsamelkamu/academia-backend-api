{
  "name": "academic-project-platform-backend",
  "version": "1.0.0",
  "description": "Backend API for Academic Project Management SaaS Platform",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "postinstall": "npx prisma generate --config src/prisma/prisma.config.ts",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:worker": "set NODE_ENV=development&& set WORKER=true&& nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:worker": "set WORKER=true&& node -r ts-node/register -r tsconfig-paths/register src/worker.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate --config src/prisma/prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config src/prisma/prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config src/prisma/prisma.config.ts",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "milestone-templates:ensure-default": "ts-node -r tsconfig-paths/register scripts/utils/ensure-default-milestone-templates.ts",
    "milestone-templates:update-default-proposal-doc": "ts-node -r tsconfig-paths/register scripts/utils/update-default-milestone-templates-proposal-doc.ts",
    "seed:admin": "node dist/prisma/seeds/platform-admin.seed.js",
    "seed": "node dist/prisma/seeds/main.seed.js",
    "db:setup": "node scripts/database/setup.js",
    "db:seed": "node scripts/database/seed.js",
    "db:reset": "node scripts/database/reset.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "academic",
    "project-management",
    "saas",
    "nestjs",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@getbrevo/brevo": "^3.0.1",
    "@nestjs/bull": "^11.0.0",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.12",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.14",
    "@paddle/paddle-node-sdk": "^3.5.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sendinblue/client": "^3.3.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "nest-winston": "^1.10.2",
    "otplib": "^12.0.1",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.12",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.2.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "prisma": "^7.3.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
