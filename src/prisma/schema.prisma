generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model BaseModel {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("_base")
}

// ========================
// TENANT/INSTITUTION
// ========================
enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model Tenant {
  id             String       @id @default(uuid())
  name           String       @db.VarChar(255)
  domain         String       @unique @db.VarChar(100)
  status         TenantStatus @default(TRIAL)
  onboardingDate DateTime     @default(now()) @map("onboarding_date")
  config         Json? // Tenant-specific configurations

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  subscription  TenantSubscription?
  departments   Department[]
  academicYears AcademicYear[]
  users         User[]
  invitations   Invitation[]
  userRoles     UserRole[]

  proposals Proposal[]
  projects  Project[]

  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("tenants")
}

// ========================
// SUBSCRIPTION PLANS
// ========================
model SubscriptionPlan {
  id           String  @id @default(uuid())
  name         String  @unique @db.VarChar(100)
  description  String?
  features     Json // Feature flags and limits
  price        Decimal @db.Decimal(10, 2)
  billingCycle String  @map("billing_cycle") // monthly, yearly
  isActive     Boolean @default(true) @map("is_active")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  subscriptions TenantSubscription[]

  @@index([name])
  @@index([isActive])
  @@map("subscription_plans")
}

model TenantSubscription {
  id                   String    @id @default(uuid())
  tenantId             String    @unique
  planId               String
  paddleSubscriptionId String?   @map("paddle_subscription_id")
  paddleCustomerId     String?   @map("paddle_customer_id")
  status               String // active, trialing, past_due, cancelled
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant           @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("tenant_subscriptions")
}

// ========================
// USER MANAGEMENT
// ========================
enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

model User {
  id             String     @id @default(uuid())
  tenantId       String
  email          String     @db.VarChar(255)
  hashedPassword String?    @map("hashed_password") @db.VarChar(255)
  firstName      String     @map("first_name") @db.VarChar(100)
  lastName       String     @map("last_name") @db.VarChar(100)
  avatarUrl      String?    @map("avatar_url")
  avatarPublicId String?    @map("avatar_public_id")
  status         UserStatus @default(PENDING)
  lastLoginAt    DateTime?  @map("last_login_at")
  emailVerified  Boolean    @default(false) @map("email_verified")

  // ========================
  // TWO-FACTOR AUTH (TOTP)
  // ========================
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?   @map("two_factor_secret")
  twoFactorVerifiedAt DateTime? @map("two_factor_verified_at")

  // ========================
  // TWO-FACTOR BACKUP CODES
  // ========================
  backupCodesResetAt DateTime? @map("backup_codes_reset_at")

  // Department assignment
  departmentId String?

  // Auditing
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  department        Department?  @relation("DepartmentUsers", fields: [departmentId], references: [id])
  headedDepartments Department[] @relation("DepartmentHead")
  roles             UserRole[]
  sentInvitations   Invitation[] @relation("InvitedBy")

  backupCodes BackupCode[]

  proposalsSubmitted Proposal[]      @relation("ProposalSubmitter")
  proposalsAdvised   Proposal[]      @relation("ProposalAdvisor")
  projectsAdvised    Project[]       @relation("ProjectAdvisor")
  projectMemberships ProjectMember[]
  advisor            Advisor?

  // Constraints
  @@unique([tenantId, email])
  @@index([tenantId, email])
  @@index([status])
  @@index([departmentId])
  @@index([createdAt])
  @@map("users")
}

// ========================
// ROLES & PERMISSIONS
// ========================
model Role {
  id           String  @id @default(uuid())
  name         String  @unique @db.VarChar(50)
  description  String?
  permissions  Json? // Permission configuration
  isSystemRole Boolean @default(false) @map("is_system_role")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles   UserRole[]
  invitations Invitation[]

  @@index([name])
  @@index([isSystemRole])
  @@map("roles")
}

model UserRole {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  roleId       String  @map("role_id")
  tenantId     String  @map("tenant_id")
  departmentId String? @map("department_id")
  assignedBy   String? @map("assigned_by")

  // Auditing
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")

  // Relations
  user       User        @relation(fields: [userId], references: [id])
  role       Role        @relation(fields: [roleId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@unique([userId, roleId, tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([tenantId])
  @@index([assignedAt])
  @@map("user_roles")
}

// ========================
// INVITATION SYSTEM
// ========================
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id          String           @id @default(uuid())
  tenantId    String
  email       String           @db.VarChar(255)
  roleId      String
  token       String           @unique @db.VarChar(64)
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime         @map("expires_at")
  invitedById String?          @map("invited_by_id")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  role      Role   @relation(fields: [roleId], references: [id])
  invitedBy User?  @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([tenantId, email])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}

// ========================
// DEPARTMENT (Basic for now)
// ========================
model Department {
  id                 String  @id @default(uuid())
  tenantId           String
  name               String  @db.VarChar(150)
  code               String  @db.VarChar(20)
  description        String?
  headOfDepartmentId String? @map("head_of_department_id")

  // Configuration
  config Json? // Department-specific settings

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  head      User?      @relation("DepartmentHead", fields: [headOfDepartmentId], references: [id])
  users     User[]     @relation("DepartmentUsers")
  userRoles UserRole[]

  proposals Proposal[]
  projects  Project[]
  advisors  Advisor[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([headOfDepartmentId])
  @@map("departments")
}

// ========================
// ACADEMIC YEARS
// ========================
model AcademicYear {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String   @db.VarChar(100) // e.g., "2023-2024"
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(false) @map("is_active")
  description String?

  // Configuration
  config Json? // Academic year specific settings

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
  @@index([startDate, endDate])
  @@map("academic_years")
}

model BackupCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  codeHash  String    @map("code_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId])
  @@index([usedAt])
  @@map("backup_codes")
}

// ========================
// PROJECT & PROPOSAL MANAGEMENT
// ========================
enum ProposalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Proposal {
  id           String         @id @default(uuid())
  tenantId     String
  departmentId String
  title        String         @db.VarChar(255)
  description  String?
  status       ProposalStatus @default(DRAFT)
  submittedBy  String         @map("submitted_by")
  advisorId    String?        @map("advisor_id")
  documents    Json? // Array of document URLs/metadata
  feedback     String?

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  submitter  User       @relation("ProposalSubmitter", fields: [submittedBy], references: [id])
  advisor    User?      @relation("ProposalAdvisor", fields: [advisorId], references: [id])
  project    Project?

  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
  @@index([submittedBy])
  @@index([advisorId])
  @@index([createdAt])
  @@map("proposals")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Project {
  id           String        @id @default(uuid())
  tenantId     String
  departmentId String
  title        String        @db.VarChar(255)
  description  String?
  status       ProjectStatus @default(ACTIVE)
  proposalId   String        @unique @map("proposal_id")
  advisorId    String        @map("advisor_id")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  department Department      @relation(fields: [departmentId], references: [id])
  proposal   Proposal        @relation(fields: [proposalId], references: [id])
  advisor    User            @relation("ProjectAdvisor", fields: [advisorId], references: [id])
  members    ProjectMember[]
  milestones Milestone[]

  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
  @@index([advisorId])
  @@index([createdAt])
  @@map("projects")
}

enum ProjectMemberRole {
  STUDENT
  ADVISOR
}

model ProjectMember {
  id        String            @id @default(uuid())
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  role      ProjectMemberRole

  // Auditing
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([role])
  @@map("project_members")
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

model Milestone {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  title       String          @db.VarChar(255)
  description String?
  dueDate     DateTime        @map("due_date")
  status      MilestoneStatus @default(PENDING)
  submittedAt DateTime?       @map("submitted_at")
  feedback    String?

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("milestones")
}

// ========================
// ADVISOR MANAGEMENT
// ========================
model Advisor {
  id           String @id @default(uuid())
  userId       String @unique
  departmentId String
  loadLimit    Int    @default(5) // Maximum projects an advisor can handle
  currentLoad  Int    @default(0) // Current number of active projects

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@index([userId])
  @@index([departmentId])
  @@index([loadLimit])
  @@index([currentLoad])
  @@map("advisors")
}
