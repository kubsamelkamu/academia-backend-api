model Milestone {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  title       String          @db.VarChar(255)
  description String?
  dueDate     DateTime        @map("due_date")
  status      MilestoneStatus @default(PENDING)
  submittedAt DateTime?       @map("submitted_at")
  feedback    String?

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])
  submissions MilestoneSubmission[]

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("milestones")
}

enum MilestoneSubmissionStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

model MilestoneSubmission {
  id          String                   @id @default(uuid())
  milestoneId String                   @map("milestone_id")

  uploadedByUserId String              @map("uploaded_by_user_id")

  fileName     String                  @map("file_name")
  mimeType     String                  @map("mime_type")
  sizeBytes    Int                     @map("size_bytes")
  fileUrl      String                  @map("file_url")
  filePublicId String                  @map("file_public_id")
  resourceType String                  @default("raw") @map("resource_type") @db.VarChar(20)

  status       MilestoneSubmissionStatus @default(SUBMITTED)
  approvedByUserId String?             @map("approved_by_user_id")
  approvedAt   DateTime?               @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  milestone  Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation("MilestoneSubmissionUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  approvedBy User?     @relation("MilestoneSubmissionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  feedbacks  MilestoneSubmissionFeedback[]

  @@index([milestoneId, createdAt])
  @@index([uploadedByUserId])
  @@index([approvedByUserId])
  @@map("milestone_submissions")
}

model MilestoneSubmissionFeedback {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  authorId     String   @map("author_id")
  authorRole   String   @map("author_role") @db.VarChar(50)
  message      String   @db.Text

  attachmentFileName     String? @map("attachment_file_name") @db.VarChar(255)
  attachmentMimeType     String? @map("attachment_mime_type") @db.VarChar(255)
  attachmentSizeBytes    Int?    @map("attachment_size_bytes")
  attachmentUrl          String? @map("attachment_url")
  attachmentPublicId     String? @map("attachment_public_id")
  attachmentResourceType String? @map("attachment_resource_type") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")

  submission MilestoneSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author     User                @relation("MilestoneSubmissionFeedbackAuthor", fields: [authorId], references: [id])

  @@index([submissionId, createdAt], map: "milestone_submission_feedbacks_submission_id_created_at_idx")
  @@index([authorId], map: "milestone_submission_feedbacks_author_id_idx")
  @@map("milestone_submission_feedbacks")
}

model MilestoneTemplate {
  id           String   @id @default(uuid())
