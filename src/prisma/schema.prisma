enum ProposalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Proposal {
  id           String         @id @default(uuid())
  tenantId     String
  departmentId String
  projectGroupId String?      @map("project_group_id")
  title        String         @db.VarChar(255)
  proposedTitles Json?        @map("proposed_titles") // Exactly 3 candidate titles
  selectedTitleIndex Int?     @map("selected_title_index")
  description  String?
  status       ProposalStatus @default(DRAFT)
  submittedBy  String         @map("submitted_by")
  advisorId    String?        @map("advisor_id")
  documents    Json? // Array of document URLs/metadata
  feedback     String?

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  projectGroup ProjectGroup? @relation(fields: [projectGroupId], references: [id])
  submitter  User       @relation("ProposalSubmitter", fields: [submittedBy], references: [id])
  advisor    User?      @relation("ProposalAdvisor", fields: [advisorId], references: [id])
  project    Project?
  feedbacks  ProposalFeedback[]
  announcements ProjectGroupAnnouncement[] @relation("ProposalAnnouncements")

  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
  @@index([submittedBy])
  @@index([projectGroupId])
  @@index([advisorId])
  @@index([createdAt])
  @@map("proposals")
}

model ProposalFeedback {
  id         String   @id @default(uuid())
  proposalId String   @map("proposal_id")
  authorId   String   @map("author_id")
  authorRole String   @map("author_role") @db.VarChar(50)
  message    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  author   User     @relation("ProposalFeedbackAuthor", fields: [authorId], references: [id])

  @@index([proposalId, createdAt], map: "proposal_feedbacks_proposal_id_created_at_idx")
  @@index([authorId], map: "proposal_feedbacks_author_id_idx")
  @@map("proposal_feedbacks")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Project {
  id           String        @id @default(uuid())
  tenantId     String
  departmentId String
  title        String        @db.VarChar(255)
  description  String?
  status       ProjectStatus @default(ACTIVE)
  proposalId   String        @unique @map("proposal_id")
  advisorId    String?       @map("advisor_id")
  milestoneTemplateId String? @map("milestone_template_id")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  department Department      @relation(fields: [departmentId], references: [id])
  proposal   Proposal        @relation(fields: [proposalId], references: [id])
  advisor    User?           @relation("ProjectAdvisor", fields: [advisorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  members    ProjectMember[]
  milestones Milestone[]
  milestoneTemplate MilestoneTemplate? @relation(fields: [milestoneTemplateId], references: [id])

  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
  @@index([advisorId])
  @@index([milestoneTemplateId])
  @@index([createdAt])
  @@map("projects")
}

enum ProjectMemberRole {
  STUDENT
  ADVISOR
}

model ProjectMember {
  id        String            @id @default(uuid())
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  role      ProjectMemberRole

  // Auditing
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([role])
  @@map("project_members")
}

