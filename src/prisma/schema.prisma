// ========================
// ADVISOR MANAGEMENT
// ========================
model Advisor {
  id           String @id @default(uuid())
  userId       String @unique
  departmentId String
  loadLimit    Int    @default(5) // Maximum projects an advisor can handle
  currentLoad  Int    @default(0) // Current number of active projects

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@index([userId])
  @@index([departmentId])
  @@index([loadLimit])
  @@index([currentLoad])
  @@map("advisors")
}

model Notification {
  id             String                 @id @default(uuid())
  tenantId       String
  userId         String
  eventType      NotificationEventType
  severity       NotificationSeverity
  title          String
  message        String
  metadata       Json? // Safe metadata like ipHash, deviceFingerprintHash, etc.
  status         NotificationStatus     @default(UNREAD)
  readAt         DateTime?              @map("read_at")
  idempotencyKey String                 @unique
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  coordinatorAdvisorNotificationRecipients CoordinatorAdvisorNotificationRecipient[]

  @@index([tenantId, userId, status])
  @@index([createdAt])
  @@map("notifications")
}

model CoordinatorAdvisorNotificationCampaign {
  id                       String                                       @id @default(uuid())
  tenantId                 String
  departmentId             String                                       @map("department_id")
  createdByUserId          String                                       @map("created_by_user_id")
  recipientMode            CoordinatorAdvisorNotificationRecipientMode  @map("recipient_mode")
  deliveryMethod           CoordinatorAdvisorNotificationDeliveryMethod @map("delivery_method")
  priority                 NotificationSeverity
  subject                  String                                       @db.VarChar(255)
  message                  String                                       @db.Text
  requestedRecipientsCount Int                                          @default(0) @map("requested_recipients_count")
  inAppDeliveredCount      Int                                          @default(0) @map("in_app_delivered_count")
  inAppFailedCount         Int                                          @default(0) @map("in_app_failed_count")
  emailQueuedCount         Int                                          @default(0) @map("email_queued_count")
  emailAcceptedCount       Int                                          @default(0) @map("email_accepted_count")
  emailDeliveredCount      Int                                          @default(0) @map("email_delivered_count")
  emailFailedCount         Int                                          @default(0) @map("email_failed_count")
  totalReachedCount        Int                                          @default(0) @map("total_reached_count")
  createdAt                DateTime                                     @default(now()) @map("created_at")
  updatedAt                DateTime                                     @updatedAt @map("updated_at")

  tenant                   Tenant                                       @relation(fields: [tenantId], references: [id])
  department               Department                                   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdBy                User                                         @relation("CoordinatorAdvisorNotificationCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  recipients               CoordinatorAdvisorNotificationRecipient[]

  @@index([tenantId, departmentId, createdAt])
  @@index([createdByUserId, createdAt])
  @@map("coordinator_advisor_notification_campaigns")
}

model CoordinatorAdvisorNotificationRecipient {
  id                     String                                    @id @default(uuid())
  campaignId             String                                    @map("campaign_id")
  tenantId               String
  departmentId           String                                    @map("department_id")
  advisorUserId          String                                    @map("advisor_user_id")
  email                  String                                    @db.VarChar(255)
  fullName               String                                    @map("full_name") @db.VarChar(255)
  inAppStatus            CoordinatorAdvisorNotificationInAppStatus @default(NOT_REQUESTED) @map("in_app_status")
  emailStatus            CoordinatorAdvisorNotificationEmailStatus @default(NOT_REQUESTED) @map("email_status")
  inAppNotificationId    String?                                   @map("in_app_notification_id")
  emailProviderMessageId String?                                   @map("email_provider_message_id") @db.VarChar(255)
  emailFailureReason     String?                                   @map("email_failure_reason") @db.Text
  readAt                 DateTime?                                 @map("read_at")
  createdAt              DateTime                                  @default(now()) @map("created_at")
  updatedAt              DateTime                                  @updatedAt @map("updated_at")

  campaign               CoordinatorAdvisorNotificationCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant                 Tenant                                    @relation(fields: [tenantId], references: [id])
  department             Department                                @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  advisorUser            User                                      @relation("CoordinatorAdvisorNotificationRecipientUser", fields: [advisorUserId], references: [id], onDelete: Cascade)
  inAppNotification      Notification?                             @relation(fields: [inAppNotificationId], references: [id], onDelete: SetNull)

  @@unique([campaignId, advisorUserId])
  @@index([tenantId, departmentId, createdAt])
  @@index([advisorUserId, createdAt])
  @@index([inAppNotificationId])
  @@index([emailProviderMessageId])
  @@map("coordinator_advisor_notification_recipients")
}

model PushSubscription {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String
  endpoint       String   @unique
  p256dh         String
  auth           String
  expirationTime BigInt?  // DOMTimeStamp (ms) from browser PushSubscription
  userAgent      String?  @db.VarChar(512)
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@index([lastUsedAt])
  @@map("push_subscriptions")
}

model DepartmentDocumentTemplate {
  id           String              @id @default(uuid())
  tenantId     String
  departmentId String
  type         DocumentTemplateType @default(OTHER)
  title        String              @db.VarChar(255)
  description  String?
  isActive     Boolean             @default(true) @map("is_active")
  createdById  String?             @map("created_by")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  createdBy  User?      @relation("DepartmentDocumentTemplateCreatedBy", fields: [createdById], references: [id])
  files      DepartmentDocumentTemplateFile[]

  @@index([tenantId])
  @@index([departmentId])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
  @@map("department_document_templates")
}

model DepartmentDocumentTemplateFile {
  id           String  @id @default(uuid())
  templateId   String  @map("template_id")

  fileName     String  @map("file_name")
  mimeType     String  @map("mime_type")
  sizeBytes    Int     @map("size_bytes")
  fileUrl      String  @map("file_url")
  filePublicId String  @map("file_public_id")
  resourceType String  @default("raw") @map("resource_type") @db.VarChar(20)

  uploadedById String? @map("uploaded_by")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  template   DepartmentDocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  uploadedBy User?                     @relation("DepartmentDocumentTemplateFileUploadedBy", fields: [uploadedById], references: [id])

  @@index([templateId])
  @@index([uploadedById])
  @@map("department_document_template_files")
}
