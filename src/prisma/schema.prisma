generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model BaseModel {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("_base")
}

// ========================
// TENANT/INSTITUTION
// ========================
enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model Tenant {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(255)
  domain         String   @unique @db.VarChar(100)
  status         TenantStatus @default(TRIAL)
  onboardingDate DateTime @default(now()) @map("onboarding_date")
  config         Json?        // Tenant-specific configurations

  // Auditing
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  subscription   TenantSubscription?
  departments    Department[]
  users          User[]
  invitations    Invitation[]
  userRoles      UserRole[]

  @@map("tenants")
  @@index([domain])
  @@index([status])
  @@index([createdAt])
}

// ========================
// SUBSCRIPTION PLANS
// ========================
model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   @unique @db.VarChar(100)
  description  String?
  features     Json     // Feature flags and limits
  price        Decimal  @db.Decimal(10, 2)
  billingCycle String   @map("billing_cycle") // monthly, yearly
  isActive     Boolean  @default(true) @map("is_active")

  // Auditing
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  subscriptions TenantSubscription[]

  @@map("subscription_plans")
  @@index([name])
  @@index([isActive])
}

model TenantSubscription {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  planId                String
  paddleSubscriptionId  String?  @map("paddle_subscription_id")
  paddleCustomerId      String?  @map("paddle_customer_id")
  status                String   // active, trialing, past_due, cancelled
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  cancelAtPeriodEnd     Boolean  @default(false) @map("cancel_at_period_end")

  // Auditing
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  plan                  SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("tenant_subscriptions")
  @@index([tenantId])
  @@index([status])
  @@index([currentPeriodEnd])
}

// ========================
// USER MANAGEMENT
// ========================
enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

model User {
  id             String     @id @default(uuid())
  tenantId       String
  email          String     @db.VarChar(255)
  hashedPassword String?    @map("hashed_password") @db.VarChar(255)
  firstName      String     @map("first_name") @db.VarChar(100)
  lastName       String     @map("last_name") @db.VarChar(100)
  avatarUrl      String?    @map("avatar_url")
  status         UserStatus @default(PENDING)
  lastLoginAt    DateTime?  @map("last_login_at")
  emailVerified  Boolean    @default(false) @map("email_verified")

  // Department assignment
  departmentId   String?

  // Auditing
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  // Relations
  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  department     Department? @relation("DepartmentUsers", fields: [departmentId], references: [id])
  headedDepartments Department[] @relation("DepartmentHead")
  roles          UserRole[]
  sentInvitations Invitation[] @relation("InvitedBy")

  // Constraints
  @@unique([tenantId, email])
  @@map("users")
  @@index([tenantId, email])
  @@index([status])
  @@index([departmentId])
  @@index([createdAt])
}

// ========================
// ROLES & PERMISSIONS
// ========================
model Role {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(50)
  description   String?
  permissions   Json?    // Permission configuration
  isSystemRole  Boolean  @default(false) @map("is_system_role")

  // Auditing
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles     UserRole[]
  invitations   Invitation[]

  @@map("roles")
  @@index([name])
  @@index([isSystemRole])
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  tenantId   String   @map("tenant_id")
  departmentId String? @map("department_id")
  assignedBy String?  @map("assigned_by")

  // Auditing
  assignedAt DateTime @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")

  // Relations
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@unique([userId, roleId, tenantId])
  @@map("user_roles")
  @@index([userId])
  @@index([roleId])
  @@index([tenantId])
  @@index([assignedAt])
}

// ========================
// INVITATION SYSTEM
// ========================
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id         String           @id @default(uuid())
  tenantId   String
  email      String           @db.VarChar(255)
  roleId     String
  token      String           @unique @db.VarChar(64)
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime         @map("expires_at")
  invitedById String?         @map("invited_by_id")

  // Auditing
  createdAt  DateTime         @default(now()) @map("created_at")

  // Relations
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  role       Role             @relation(fields: [roleId], references: [id])
  invitedBy  User?            @relation("InvitedBy", fields: [invitedById], references: [id])

  @@map("invitations")
  @@index([tenantId, email])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// ========================
// DEPARTMENT (Basic for now)
// ========================
model Department {
  id                    String   @id @default(uuid())
  tenantId              String
  name                  String   @db.VarChar(150)
  code                  String   @db.VarChar(20)
  description           String?
  headOfDepartmentId    String?  @map("head_of_department_id")

  // Configuration
  config                Json?    // Department-specific settings

  // Auditing
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  head                  User?    @relation("DepartmentHead", fields: [headOfDepartmentId], references: [id])
  users                 User[]   @relation("DepartmentUsers")
  userRoles              UserRole[]

  @@map("departments")
  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([headOfDepartmentId])
}