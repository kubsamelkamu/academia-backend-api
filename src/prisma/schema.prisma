  coordinatorAdvisorNotificationRecipients CoordinatorAdvisorNotificationRecipient[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([headOfDepartmentId])
  @@index([defaultMilestoneTemplateId])
  @@map("departments")
}

  // ========================
