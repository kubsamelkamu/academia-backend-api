  createdBy   User       @relation("DepartmentAnnouncementCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, departmentId, createdAt])
  @@index([departmentId, createdAt])
  @@index([createdByUserId])
  @@index([deadlineAt])
  @@index([expiredAt])
  @@map("department_announcements")
}

model TenantVerificationRequest {
