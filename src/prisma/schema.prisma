generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model BaseModel {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("_base")
}

// ========================
// TENANT/INSTITUTION
// ========================
enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

// ========================
// TENANT VERIFICATION (INSTITUTION KYC)
// ========================
enum TenantVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tenant {
  id             String       @id @default(uuid())
  name           String       @db.VarChar(255)
  domain         String       @unique @db.VarChar(100)
  status         TenantStatus @default(TRIAL)
  onboardingDate DateTime     @default(now()) @map("onboarding_date")
  config         Json? // Tenant-specific configurations

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  departments   Department[]
  academicYears AcademicYear[]
  users         User[]
  students      Student[]
  invitations   Invitation[]
  invitationMessageTemplates InvitationMessageTemplate[]
  userRoles     UserRole[]

  passwordResetOtps PasswordResetOtp[]
  emailVerificationOtps EmailVerificationOtp[]

  proposals Proposal[]
  projects  Project[]
  milestoneTemplates MilestoneTemplate[]
  departmentDocumentTemplates DepartmentDocumentTemplate[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]

  verificationRequests TenantVerificationRequest[]

  groupLeaderRequests GroupLeaderRequest[]

  projectGroups ProjectGroup[]
  projectGroupInvitations ProjectGroupInvitation[]
  projectGroupJoinRequests ProjectGroupJoinRequest[]
  projectGroupAnnouncements ProjectGroupAnnouncement[]
  departmentAnnouncements DepartmentAnnouncement[]
  coordinatorAdvisorNotificationCampaigns CoordinatorAdvisorNotificationCampaign[]
  coordinatorAdvisorNotificationRecipients CoordinatorAdvisorNotificationRecipient[]

  projectGroupChatRooms ProjectGroupChatRoom[]
  projectGroupChatMessages ProjectGroupChatMessage[]
  projectGroupChatMessageReads ProjectGroupChatMessageRead[]
  projectGroupChatMessageReactions ProjectGroupChatMessageReaction[]
  projectGroupChatPinnedMessages ProjectGroupChatPinnedMessage[]

  projectGroupTasks ProjectGroupTask[]

  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("tenants")
}

// ========================
// USER MANAGEMENT
// ========================
enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

model User {
  id             String     @id @default(uuid())
  tenantId       String
  email          String     @db.VarChar(255)
  hashedPassword String?    @map("hashed_password") @db.VarChar(255)
  mustChangePassword Boolean @default(false) @map("must_change_password")
  firstName      String     @map("first_name") @db.VarChar(100)
  lastName       String     @map("last_name") @db.VarChar(100)
  avatarUrl      String?    @map("avatar_url")
  avatarPublicId String?    @map("avatar_public_id")
  status         UserStatus @default(PENDING)
  lastLoginAt    DateTime?  @map("last_login_at")
  firstLoginAt   DateTime?  @map("first_login_at") // Set on first login
  statusUploadDeadline DateTime? @map("status_upload_deadline") // 2 days after first login
  emailVerified  Boolean    @default(false) @map("email_verified")
  studentProfileReminderSentAt DateTime? @map("student_profile_reminder_sent_at")

  // ========================
  // TWO-FACTOR AUTH (TOTP)
  // ========================
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?   @map("two_factor_secret")
  twoFactorVerifiedAt DateTime? @map("two_factor_verified_at")

  // ========================
  // TWO-FACTOR BACKUP CODES
  // ========================
  backupCodesResetAt DateTime? @map("backup_codes_reset_at")

  // Department assignment
  departmentId String?

  // Auditing
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  department        Department?  @relation("DepartmentUsers", fields: [departmentId], references: [id])
  headedDepartments Department[] @relation("DepartmentHead")
  roles             UserRole[]
  sentInvitations   Invitation[] @relation("InvitedBy")
  revokedInvitations Invitation[] @relation("RevokedBy")

  invitationMessageTemplatesCreated InvitationMessageTemplate[] @relation("InvitationMessageTemplateCreatedBy")

  backupCodes BackupCode[]

  passwordResetOtps PasswordResetOtp[]
  emailVerificationOtps EmailVerificationOtp[]

  proposalsSubmitted Proposal[]      @relation("ProposalSubmitter")
  proposalsAdvised   Proposal[]      @relation("ProposalAdvisor")
  proposalFeedbacksAuthored ProposalFeedback[] @relation("ProposalFeedbackAuthor")
  projectsAdvised    Project[]       @relation("ProjectAdvisor")
  projectMemberships ProjectMember[]
  advisor            Advisor?
  student            Student?
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]

  tenantVerificationSubmissions TenantVerificationRequest[] @relation("TenantVerificationSubmittedBy")
  tenantVerificationReviews     TenantVerificationRequest[] @relation("TenantVerificationReviewedBy")

  groupSizeSettingsCreated DepartmentGroupSizeSetting[] @relation("GroupSizeCreatedBy")
  groupSizeSettingsUpdated DepartmentGroupSizeSetting[] @relation("GroupSizeUpdatedBy")

  milestoneTemplatesCreated MilestoneTemplate[] @relation("MilestoneTemplateCreatedBy")

  departmentDocumentTemplatesCreated DepartmentDocumentTemplate[] @relation("DepartmentDocumentTemplateCreatedBy")
  departmentDocumentTemplateFilesUploaded DepartmentDocumentTemplateFile[] @relation("DepartmentDocumentTemplateFileUploadedBy")

  milestoneSubmissionsUploaded MilestoneSubmission[] @relation("MilestoneSubmissionUploadedBy")
  milestoneSubmissionsApproved MilestoneSubmission[] @relation("MilestoneSubmissionApprovedBy")
  milestoneSubmissionFeedbacksAuthored MilestoneSubmissionFeedback[] @relation("MilestoneSubmissionFeedbackAuthor")

  groupLeaderRequest GroupLeaderRequest? @relation("GroupLeaderRequestStudent")
  groupLeaderRequestsReviewed GroupLeaderRequest[] @relation("GroupLeaderRequestReviewedBy")

  projectGroupLed ProjectGroup? @relation("ProjectGroupLeader")
  projectGroupsReviewed ProjectGroup[] @relation("ProjectGroupReviewedBy")
  projectGroupMemberships ProjectGroupMember[]

  projectGroupInvitationsSent ProjectGroupInvitation[] @relation("ProjectGroupInvitationLeader")
  projectGroupInvitationsReceived ProjectGroupInvitation[] @relation("ProjectGroupInvitationInvitedUser")

  projectGroupJoinRequestsReceived ProjectGroupJoinRequest[] @relation("ProjectGroupJoinRequestLeader")
  projectGroupJoinRequestsCreated ProjectGroupJoinRequest[] @relation("ProjectGroupJoinRequestRequestedBy")
  projectGroupJoinRequestsDecided ProjectGroupJoinRequest[] @relation("ProjectGroupJoinRequestDecidedBy")

  projectGroupAnnouncementsCreated ProjectGroupAnnouncement[] @relation("ProjectGroupAnnouncementCreatedBy")
  departmentAnnouncementsCreated DepartmentAnnouncement[] @relation("DepartmentAnnouncementCreatedBy")
  coordinatorAdvisorNotificationCampaignsCreated CoordinatorAdvisorNotificationCampaign[] @relation("CoordinatorAdvisorNotificationCampaignCreatedBy")
  coordinatorAdvisorNotificationRecipients CoordinatorAdvisorNotificationRecipient[] @relation("CoordinatorAdvisorNotificationRecipientUser")

  projectGroupChatMessagesSent ProjectGroupChatMessage[] @relation("ProjectGroupChatMessageSender")
  projectGroupChatMessageReads ProjectGroupChatMessageRead[] @relation("ProjectGroupChatMessageReadUser")
  projectGroupChatMessageReactions ProjectGroupChatMessageReaction[] @relation("ProjectGroupChatMessageReactionUser")
  projectGroupChatPinnedMessages ProjectGroupChatPinnedMessage[] @relation("ProjectGroupChatPinnedBy")

  projectGroupTasksCreated  ProjectGroupTask[] @relation("ProjectGroupTaskCreatedBy")
  projectGroupTasksAssigned ProjectGroupTask[] @relation("ProjectGroupTaskAssignedTo")

  // Constraints
  @@unique([tenantId, email])
  @@index([tenantId, email])
  @@index([status])
  @@index([departmentId])
  @@index([studentProfileReminderSentAt], map: "users_student_profile_reminder_sent_at_idx")
  @@index([createdAt])
  @@map("users")
}

// ========================
// STUDENT PROFILE
// ========================
model Student {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String   @unique

  bio          String?
  githubUrl    String?
  linkedinUrl  String?
  portfolioUrl String?
  techStack    Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("students")
}

// ========================
// GROUP LEADER REQUESTS
// ========================
enum GroupLeaderRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ========================
// PROJECT GROUP INVITATIONS
// ========================
enum ProjectGroupInvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

enum ProjectGroupStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProjectGroupJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
  CANCELLED
}

enum ProjectGroupAnnouncementPriority {
  HIGH
  MEDIUM
  LOW
}

enum ProjectGroupAnnouncementKind {
  GENERAL
  PROPOSAL_REJECTION_REMINDER
}

enum ProjectGroupAnnouncementAttachmentType {
  NONE
  FILE
  LINK
}

enum ProjectGroupAnnouncementAttachmentResourceType {
  image
  raw
}

enum DepartmentAnnouncementActionType {
  FORM_PROJECT_GROUP
  SUBMIT_PROPOSAL
  UPLOAD_DOCUMENT
  REGISTER_PRESENTATION
  CUSTOM_ACTION
}

enum ProjectGroupChatMessageAttachmentResourceType {
  image
  raw
}

enum ProjectGroupTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model GroupLeaderRequest {
  id            String                   @id @default(uuid())
  tenantId      String
  departmentId  String
  studentUserId String                   @unique

  applicationMessage String?             @map("application_message") @db.VarChar(1000)

  status        GroupLeaderRequestStatus @default(PENDING)
  reviewedByUserId String?               @map("reviewed_by_user_id")
  reviewedAt    DateTime?                @map("reviewed_at")
  rejectionReason String?                @map("rejection_reason") @db.VarChar(500)

  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department    Department               @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  studentUser   User                     @relation("GroupLeaderRequestStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  reviewedBy    User?                    @relation("GroupLeaderRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, departmentId, status])
  @@index([tenantId, status])
  @@index([departmentId, status])
  @@index([createdAt])
  @@map("group_leader_requests")
}

// ========================
// PROJECT GROUPS (created by approved group leaders)
// ========================
model ProjectGroup {
  id           String   @id @default(uuid())
  tenantId     String
  departmentId String

  leaderUserId String   @unique @map("leader_user_id")
  name         String   @db.VarChar(255)
  objectives   String?  @db.VarChar(2000)
  technologies Json?    @map("technologies")

  status      ProjectGroupStatus @default(DRAFT)
  submittedAt DateTime?          @map("submitted_at")

  reviewedByUserId String?       @map("reviewed_by_user_id")
  reviewedAt       DateTime?     @map("reviewed_at")
  rejectionReason  String?       @map("rejection_reason") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  leader     User        @relation("ProjectGroupLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  reviewedBy User?       @relation("ProjectGroupReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  members    ProjectGroupMember[]
  proposals  Proposal[]
  invitations ProjectGroupInvitation[]
  joinRequests ProjectGroupJoinRequest[]
  announcements ProjectGroupAnnouncement[]
  chatRoom     ProjectGroupChatRoom?

  tasks ProjectGroupTask[]

  @@index([tenantId, departmentId])
  @@index([tenantId, leaderUserId])
  @@index([tenantId, departmentId, status])
  @@index([createdAt])
  @@map("project_groups")
}

model ProjectGroupTask {
  id             String               @id @default(uuid())
  tenantId       String
  projectGroupId String               @map("project_group_id")

  createdByUserId  String             @map("created_by_user_id")
  assignedToUserId String?            @map("assigned_to_user_id")

  title       String                  @db.VarChar(255)
  description String?                 @db.VarChar(5000)
  dueDate      DateTime?              @map("due_date")

  status ProjectGroupTaskStatus @default(TODO)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectGroup ProjectGroup @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ProjectGroupTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignedTo  User?       @relation("ProjectGroupTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, projectGroupId])
  @@index([projectGroupId, status])
  @@index([assignedToUserId, status])
  @@index([createdAt])
  @@map("project_group_tasks")
}

// ========================
// PROJECT GROUP CHAT (APPROVED groups only)
// ========================
model ProjectGroupChatRoom {
  id            String   @id @default(uuid())
  tenantId      String
  projectGroupId String  @unique @map("project_group_id")

  createdAt DateTime @default(now()) @map("created_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectGroup ProjectGroup @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)
  messages    ProjectGroupChatMessage[]
  reads       ProjectGroupChatMessageRead[]
  reactions   ProjectGroupChatMessageReaction[]
  pins        ProjectGroupChatPinnedMessage[]

  @@index([tenantId])
  @@index([projectGroupId])
  @@map("project_group_chat_rooms")
}

model ProjectGroupChatMessage {
  id        String   @id @default(uuid())
  tenantId  String
  roomId    String   @map("room_id")

  senderUserId String @map("sender_user_id")
  text      String?  @db.VarChar(5000)

  replyToMessageId String? @map("reply_to_message_id")

  attachmentUrl       String?  @map("attachment_url")
  attachmentPublicId  String?  @map("attachment_public_id")
  attachmentResourceType ProjectGroupChatMessageAttachmentResourceType? @map("attachment_resource_type")
  attachmentFileName  String?  @map("attachment_file_name")
  attachmentMimeType  String?  @map("attachment_mime_type")
  attachmentSizeBytes Int?     @map("attachment_size_bytes")

  createdAt DateTime @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room   ProjectGroupChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User   @relation("ProjectGroupChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  replyTo ProjectGroupChatMessage? @relation("ProjectGroupChatMessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies ProjectGroupChatMessage[] @relation("ProjectGroupChatMessageReply")
  reads  ProjectGroupChatMessageRead[]
  reactions ProjectGroupChatMessageReaction[]
  pins      ProjectGroupChatPinnedMessage[]

  @@index([tenantId, roomId, createdAt])
  @@index([roomId, createdAt])
  @@index([senderUserId])
  @@index([replyToMessageId])
  @@map("project_group_chat_messages")
}

model ProjectGroupChatMessageRead {
  id        String   @id @default(uuid())
  tenantId  String
  roomId    String   @map("room_id")
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room   ProjectGroupChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message ProjectGroupChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user   User   @relation("ProjectGroupChatMessageReadUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([tenantId, roomId])
  @@index([roomId, userId, readAt])
  @@index([userId, readAt])
  @@map("project_group_chat_message_reads")
}

model ProjectGroupChatMessageReaction {
  id        String   @id @default(uuid())
  tenantId  String
  roomId    String   @map("room_id")
  messageId String   @map("message_id")
  userId    String   @map("user_id")

  emoji     String   @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room    ProjectGroupChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message ProjectGroupChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User                 @relation("ProjectGroupChatMessageReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([tenantId, roomId])
  @@index([roomId, messageId])
  @@index([userId])
  @@map("project_group_chat_message_reactions")
}

model ProjectGroupChatPinnedMessage {
  id             String   @id @default(uuid())
  tenantId       String
  roomId         String   @map("room_id")
  messageId      String   @map("message_id")
  pinnedByUserId String   @map("pinned_by_user_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room     ProjectGroupChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message  ProjectGroupChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy User                 @relation("ProjectGroupChatPinnedBy", fields: [pinnedByUserId], references: [id], onDelete: Cascade)

  @@unique([roomId, messageId])
  @@index([tenantId, roomId])
  @@index([roomId, pinnedAt])
  @@index([pinnedByUserId])
  @@map("project_group_chat_pinned_messages")
}

model ProjectGroupMember {
  id            String      @id @default(uuid())
  projectGroupId String     @map("project_group_id")
  userId        String      @map("user_id")

  joinedAt DateTime @default(now()) @map("joined_at")

  projectGroup ProjectGroup @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectGroupId, userId])
  @@unique([userId])
  @@index([projectGroupId])
  @@index([userId])
  @@index([joinedAt])
  @@map("project_group_members")
}

model ProjectGroupInvitation {
  id            String                      @id @default(uuid())
  tenantId      String
  departmentId  String
  projectGroupId String                     @map("project_group_id")

  leaderUserId  String                      @map("leader_user_id")
  invitedUserId String                      @map("invited_user_id")
  invitedEmail  String                      @map("invited_email") @db.VarChar(255)

  token         String                      @unique @db.VarChar(128)
  status        ProjectGroupInvitationStatus @default(PENDING)
  expiresAt     DateTime                    @map("expires_at")
  decidedAt     DateTime?                   @map("decided_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department  Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  projectGroup ProjectGroup @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)
  leader      User        @relation("ProjectGroupInvitationLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  invitedUser User        @relation("ProjectGroupInvitationInvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, departmentId])
  @@index([projectGroupId, status])
  @@index([invitedUserId, status])
  @@index([leaderUserId, status])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("project_group_invitations")
}

model ProjectGroupJoinRequest {
  id            String                       @id @default(uuid())
  tenantId      String
  departmentId  String
  projectGroupId String                      @map("project_group_id")

  leaderUserId      String                   @map("leader_user_id")
  requestedByUserId String                   @map("requested_by_user_id")

  message String?                            @db.VarChar(1000)

  status            ProjectGroupJoinRequestStatus @default(PENDING)
  decidedAt         DateTime?                 @map("decided_at")
  decidedByUserId   String?                   @map("decided_by_user_id")
  rejectionReason   String?                   @map("rejection_reason") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  projectGroup ProjectGroup @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)
  leader       User        @relation("ProjectGroupJoinRequestLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  requestedBy  User        @relation("ProjectGroupJoinRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  decidedBy    User?       @relation("ProjectGroupJoinRequestDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectGroupId, requestedByUserId])
  @@index([tenantId, departmentId])
  @@index([projectGroupId, status])
  @@index([requestedByUserId, status])
  @@index([leaderUserId, status])
  @@index([createdAt])
  @@map("project_group_join_requests")
}

model ProjectGroupAnnouncement {
  id            String   @id @default(uuid())
  tenantId      String
  departmentId  String
  projectGroupId String  @map("project_group_id")
  proposalId    String?  @map("proposal_id")

  createdByUserId String @map("created_by_user_id")

  title    String                           @db.VarChar(255)
  kind     ProjectGroupAnnouncementKind     @default(GENERAL)
  priority ProjectGroupAnnouncementPriority @default(MEDIUM)
  message  String                           @db.VarChar(5000)

  attachmentType ProjectGroupAnnouncementAttachmentType @default(NONE) @map("attachment_type")
  attachmentUrl  String?                               @map("attachment_url")
  attachmentPublicId String?                           @map("attachment_public_id")
  attachmentResourceType ProjectGroupAnnouncementAttachmentResourceType? @map("attachment_resource_type")
  attachmentFileName String?                           @map("attachment_file_name")
  attachmentMimeType String?                           @map("attachment_mime_type")
  attachmentSizeBytes Int?                             @map("attachment_size_bytes")

  deadlineAt DateTime? @map("deadline_at")
  disableAfterDeadline Boolean @default(true) @map("disable_after_deadline")
  expiredAt DateTime? @map("expired_at")

  createdNotificationSentAt DateTime? @map("created_notification_sent_at")
  reminder24hSentAt DateTime?         @map("reminder_24h_sent_at")
  reminder1hSentAt DateTime?          @map("reminder_1h_sent_at")
  deadlinePassedSentAt DateTime?      @map("deadline_passed_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  projectGroup ProjectGroup @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)
  proposal     Proposal?   @relation("ProposalAnnouncements", fields: [proposalId], references: [id], onDelete: SetNull)
  createdBy    User        @relation("ProjectGroupAnnouncementCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, departmentId])
  @@index([projectGroupId, createdAt])
  @@index([createdByUserId])
  @@index([proposalId])
  @@index([deadlineAt])
  @@index([expiredAt])
  @@map("project_group_announcements")
}

model DepartmentAnnouncement {
  id            String   @id @default(uuid())
  tenantId      String
  departmentId  String

  createdByUserId String @map("created_by_user_id")

  title      String                           @db.VarChar(255)
  message    String                           @db.VarChar(5000)
  actionType DepartmentAnnouncementActionType @map("action_type")
  actionLabel String?                         @map("action_label") @db.VarChar(120)
  actionUrl   String?                         @map("action_url")

  deadlineAt DateTime? @map("deadline_at")
  disableAfterDeadline Boolean @default(true) @map("disable_after_deadline")
  expiredAt DateTime? @map("expired_at")

  createdNotificationSentAt DateTime? @map("created_notification_sent_at")
  reminder24hSentAt DateTime?         @map("reminder_24h_sent_at")
  reminder1hSentAt DateTime?          @map("reminder_1h_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
