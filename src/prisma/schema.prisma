generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model BaseModel {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("_base")
}

// ========================
// TENANT/INSTITUTION
// ========================
enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

// ========================
// TENANT VERIFICATION (INSTITUTION KYC)
// ========================
enum TenantVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tenant {
  id             String       @id @default(uuid())
  name           String       @db.VarChar(255)
  domain         String       @unique @db.VarChar(100)
  status         TenantStatus @default(TRIAL)
  onboardingDate DateTime     @default(now()) @map("onboarding_date")
  config         Json? // Tenant-specific configurations

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  departments   Department[]
  academicYears AcademicYear[]
  users         User[]
  students      Student[]
  invitations   Invitation[]
  invitationMessageTemplates InvitationMessageTemplate[]
  userRoles     UserRole[]

  passwordResetOtps PasswordResetOtp[]
  emailVerificationOtps EmailVerificationOtp[]

  proposals Proposal[]
  projects  Project[]
  milestoneTemplates MilestoneTemplate[]
  departmentDocumentTemplates DepartmentDocumentTemplate[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]

  verificationRequests TenantVerificationRequest[]

  groupLeaderRequests GroupLeaderRequest[]

  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("tenants")
}

// ========================
// USER MANAGEMENT
// ========================
enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

model User {
  id             String     @id @default(uuid())
  tenantId       String
  email          String     @db.VarChar(255)
  hashedPassword String?    @map("hashed_password") @db.VarChar(255)
  mustChangePassword Boolean @default(false) @map("must_change_password")
  firstName      String     @map("first_name") @db.VarChar(100)
  lastName       String     @map("last_name") @db.VarChar(100)
  avatarUrl      String?    @map("avatar_url")
  avatarPublicId String?    @map("avatar_public_id")
  status         UserStatus @default(PENDING)
  lastLoginAt    DateTime?  @map("last_login_at")
  firstLoginAt   DateTime?  @map("first_login_at") // Set on first login
  statusUploadDeadline DateTime? @map("status_upload_deadline") // 2 days after first login
  emailVerified  Boolean    @default(false) @map("email_verified")
  studentProfileReminderSentAt DateTime? @map("student_profile_reminder_sent_at")

  // ========================
  // TWO-FACTOR AUTH (TOTP)
  // ========================
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?   @map("two_factor_secret")
  twoFactorVerifiedAt DateTime? @map("two_factor_verified_at")

  // ========================
  // TWO-FACTOR BACKUP CODES
  // ========================
  backupCodesResetAt DateTime? @map("backup_codes_reset_at")

  // Department assignment
  departmentId String?

  // Auditing
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  department        Department?  @relation("DepartmentUsers", fields: [departmentId], references: [id])
  headedDepartments Department[] @relation("DepartmentHead")
  roles             UserRole[]
  sentInvitations   Invitation[] @relation("InvitedBy")
  revokedInvitations Invitation[] @relation("RevokedBy")

  invitationMessageTemplatesCreated InvitationMessageTemplate[] @relation("InvitationMessageTemplateCreatedBy")

  backupCodes BackupCode[]

  passwordResetOtps PasswordResetOtp[]
  emailVerificationOtps EmailVerificationOtp[]

  proposalsSubmitted Proposal[]      @relation("ProposalSubmitter")
  proposalsAdvised   Proposal[]      @relation("ProposalAdvisor")
  projectsAdvised    Project[]       @relation("ProjectAdvisor")
  projectMemberships ProjectMember[]
  advisor            Advisor?
  student            Student?
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]

  tenantVerificationSubmissions TenantVerificationRequest[] @relation("TenantVerificationSubmittedBy")
  tenantVerificationReviews     TenantVerificationRequest[] @relation("TenantVerificationReviewedBy")

  groupSizeSettingsCreated DepartmentGroupSizeSetting[] @relation("GroupSizeCreatedBy")
  groupSizeSettingsUpdated DepartmentGroupSizeSetting[] @relation("GroupSizeUpdatedBy")

  milestoneTemplatesCreated MilestoneTemplate[] @relation("MilestoneTemplateCreatedBy")

  departmentDocumentTemplatesCreated DepartmentDocumentTemplate[] @relation("DepartmentDocumentTemplateCreatedBy")
  departmentDocumentTemplateFilesUploaded DepartmentDocumentTemplateFile[] @relation("DepartmentDocumentTemplateFileUploadedBy")

  groupLeaderRequest GroupLeaderRequest? @relation("GroupLeaderRequestStudent")
  groupLeaderRequestsReviewed GroupLeaderRequest[] @relation("GroupLeaderRequestReviewedBy")

  // Constraints
  @@unique([tenantId, email])
  @@index([tenantId, email])
  @@index([status])
  @@index([departmentId])
  @@index([studentProfileReminderSentAt], map: "users_student_profile_reminder_sent_at_idx")
  @@index([createdAt])
  @@map("users")
}

// ========================
// STUDENT PROFILE
// ========================
model Student {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String   @unique

  bio          String?
  githubUrl    String?
  linkedinUrl  String?
  portfolioUrl String?
  techStack    Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("students")
}

// ========================
// GROUP LEADER REQUESTS
// ========================
enum GroupLeaderRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model GroupLeaderRequest {
  id            String                   @id @default(uuid())
  tenantId      String
  departmentId  String
  studentUserId String                   @unique

  applicationMessage String?             @map("application_message") @db.VarChar(1000)

  status        GroupLeaderRequestStatus @default(PENDING)
  reviewedByUserId String?               @map("reviewed_by_user_id")
  reviewedAt    DateTime?                @map("reviewed_at")
  rejectionReason String?                @map("rejection_reason") @db.VarChar(500)

  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department    Department               @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  studentUser   User                     @relation("GroupLeaderRequestStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  reviewedBy    User?                    @relation("GroupLeaderRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, departmentId, status])
  @@index([tenantId, status])
  @@index([departmentId, status])
  @@index([createdAt])
  @@map("group_leader_requests")
}

model TenantVerificationRequest {
  id                String                   @id @default(uuid())
  tenantId           String                   @map("tenant_id")
  submittedByUserId  String                   @map("submitted_by_user_id")
  status             TenantVerificationStatus @default(PENDING)

  documentUrl       String  @map("document_url")
  documentPublicId  String  @map("document_public_id")
  fileName          String? @map("file_name")
  mimeType          String? @map("mime_type")
  sizeBytes         Int?    @map("size_bytes")

  reviewedByUserId String?  @map("reviewed_by_user_id")
  reviewedAt       DateTime? @map("reviewed_at")
  reviewReason     String?  @map("review_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedBy User   @relation("TenantVerificationSubmittedBy", fields: [submittedByUserId], references: [id])
  reviewedBy  User?  @relation("TenantVerificationReviewedBy", fields: [reviewedByUserId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([submittedByUserId])
  @@index([reviewedByUserId])
  @@index([createdAt])
  @@map("tenant_verification_requests")
}

// ========================
// ROLES & PERMISSIONS
// ========================
model Role {
  id           String  @id @default(uuid())
  name         String  @unique @db.VarChar(50)
  description  String?
  permissions  Json? // Permission configuration
  isSystemRole Boolean @default(false) @map("is_system_role")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles   UserRole[]
  invitations Invitation[]

  @@index([name])
  @@index([isSystemRole])
  @@map("roles")
}

model UserRole {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  roleId       String  @map("role_id")
  tenantId     String  @map("tenant_id")
  departmentId String? @map("department_id")
  assignedBy   String? @map("assigned_by")

  // Auditing
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")

  // Relations
  user       User        @relation(fields: [userId], references: [id])
  role       Role        @relation(fields: [roleId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@unique([userId, roleId, tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([tenantId])
  @@index([assignedAt])
  @@map("user_roles")
}

// ========================
// INVITATION SYSTEM
// ========================
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id          String           @id @default(uuid())
  tenantId    String
  departmentId String?          @map("department_id")
  email       String           @db.VarChar(255)
  inviteeFirstName String?      @map("invitee_first_name") @db.VarChar(100)
  inviteeLastName  String?      @map("invitee_last_name") @db.VarChar(100)
  roleId      String
  token       String           @unique @db.VarChar(64)
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime         @map("expires_at")
  invitedById String?          @map("invited_by_id")

  // Audit fields
  acceptedAt  DateTime?        @map("accepted_at")
  revokedAt   DateTime?        @map("revoked_at")
  revokedById String?          @map("revoked_by_id")
  lastSentAt  DateTime?        @map("last_sent_at")
  sendCount   Int              @default(0) @map("send_count")
  lastSendError String?        @map("last_send_error") @db.VarChar(500)

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  role      Role   @relation(fields: [roleId], references: [id])
  invitedBy User?  @relation("InvitedBy", fields: [invitedById], references: [id])
  revokedBy User?  @relation("RevokedBy", fields: [revokedById], references: [id])

  @@index([tenantId, email])
  @@index([departmentId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}

model InvitationMessageTemplate {
  id           String  @id @default(uuid())
  tenantId     String
  departmentId String? @map("department_id")
  name         String  @db.VarChar(100)
  subject      String? @db.VarChar(200)
  message      String?
  createdById  String  @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  createdBy  User        @relation("InvitationMessageTemplateCreatedBy", fields: [createdById], references: [id])

  @@unique([tenantId, departmentId, name])
  @@index([tenantId])
  @@index([departmentId])
  @@index([createdById])
  @@map("invitation_message_templates")
}

//  ========================
// DEPARTMENT (Basic for now)
//  ========================
model Department {
  id                 String  @id @default(uuid())
  tenantId           String
  name               String  @db.VarChar(150)
  code               String  @db.VarChar(20)
  description        String?
  headOfDepartmentId String? @map("head_of_department_id")

  // Configuration
  config Json? // Department-specific settings

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  head      User?      @relation("DepartmentHead", fields: [headOfDepartmentId], references: [id])
  users     User[]     @relation("DepartmentUsers")
  userRoles UserRole[]
  invitations Invitation[]
  invitationMessageTemplates InvitationMessageTemplate[]

  proposals Proposal[]
  projects  Project[]
  advisors  Advisor[]
  groupSizeSetting DepartmentGroupSizeSetting?
  milestoneTemplates MilestoneTemplate[]
  documentTemplates DepartmentDocumentTemplate[]

  groupLeaderRequests GroupLeaderRequest[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([headOfDepartmentId])
  @@map("departments")
}

  // ========================
  // DEPARTMENT GROUP SIZE SETTINGS
  // ========================
  model DepartmentGroupSizeSetting {
    id            String   @id @default(uuid())
    departmentId  String
    minGroupSize  Int      @default(2)
    maxGroupSize  Int      @default(6)
    createdById   String?
    updatedById   String?
    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    // Relations
    department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
    createdBy  User?      @relation("GroupSizeCreatedBy", fields: [createdById], references: [id])
    updatedBy  User?      @relation("GroupSizeUpdatedBy", fields: [updatedById], references: [id])

    @@unique([departmentId])
    @@index([departmentId])
    @@map("department_group_size_settings")
  }

// ========================
// ACADEMIC YEARS
// ========================
model AcademicYear {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String   @db.VarChar(100) // e.g., "2023-2024"
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(false) @map("is_active")
  description String?

  // Configuration
  config Json? // Academic year specific settings

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
  @@index([startDate, endDate])
  @@map("academic_years")
}

model BackupCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  codeHash  String    @map("code_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId])
  @@index([usedAt])
  @@map("backup_codes")
}

model PasswordResetOtp {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String   @db.VarChar(255)
  userId    String?  @map("user_id")

  otpHash String @map("otp_hash") @db.VarChar(255)
  otpSalt String @map("otp_salt") @db.VarChar(64)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  attempts    Int       @default(0)
  lockedUntil DateTime? @map("locked_until")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, email])
  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([lockedUntil])
  @@map("password_reset_otps")
}

model EmailVerificationOtp {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String   @db.VarChar(255)
  userId    String?  @map("user_id")

  otpHash String @map("otp_hash") @db.VarChar(255)
  otpSalt String @map("otp_salt") @db.VarChar(64)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  attempts    Int       @default(0)
  lockedUntil DateTime? @map("locked_until")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, email])
  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([lockedUntil])
  @@map("email_verification_otps")
}

// ========================
// PROJECT & PROPOSAL MANAGEMENT
// ========================
enum ProposalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Proposal {
  id           String         @id @default(uuid())
  tenantId     String
  departmentId String
  title        String         @db.VarChar(255)
  description  String?
  status       ProposalStatus @default(DRAFT)
  submittedBy  String         @map("submitted_by")
  advisorId    String?        @map("advisor_id")
  documents    Json? // Array of document URLs/metadata
  feedback     String?

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  submitter  User       @relation("ProposalSubmitter", fields: [submittedBy], references: [id])
  advisor    User?      @relation("ProposalAdvisor", fields: [advisorId], references: [id])
  project    Project?

  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
  @@index([submittedBy])
  @@index([advisorId])
  @@index([createdAt])
  @@map("proposals")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Project {
  id           String        @id @default(uuid())
  tenantId     String
  departmentId String
  title        String        @db.VarChar(255)
  description  String?
  status       ProjectStatus @default(ACTIVE)
  proposalId   String        @unique @map("proposal_id")
  advisorId    String        @map("advisor_id")
  milestoneTemplateId String? @map("milestone_template_id")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  department Department      @relation(fields: [departmentId], references: [id])
  proposal   Proposal        @relation(fields: [proposalId], references: [id])
  advisor    User            @relation("ProjectAdvisor", fields: [advisorId], references: [id])
  members    ProjectMember[]
  milestones Milestone[]
  milestoneTemplate MilestoneTemplate? @relation(fields: [milestoneTemplateId], references: [id])

  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
  @@index([advisorId])
  @@index([milestoneTemplateId])
  @@index([createdAt])
  @@map("projects")
}

enum ProjectMemberRole {
  STUDENT
  ADVISOR
}

model ProjectMember {
  id        String            @id @default(uuid())
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  role      ProjectMemberRole

  // Auditing
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([role])
  @@map("project_members")
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum NotificationEventType {
  SECURITY_PASSWORD_RESET_REQUESTED
  SECURITY_PASSWORD_RESET_SUCCESS
  SECURITY_PASSWORD_CHANGED
  SECURITY_SUSPICIOUS_RESET_ACTIVITY
  SYSTEM_ACCOUNT_LOCKED
  PROFILE_NAME_CHANGED
  PROFILE_AVATAR_UPDATED

  DEPARTMENT_GROUP_SIZE_UPDATED

  MILESTONE_TEMPLATE_CREATED

  DEPARTMENT_DOCUMENT_TEMPLATE_CREATED

  DEPARTMENT_DOCUMENT_TEMPLATE_UPDATED
  DEPARTMENT_DOCUMENT_TEMPLATE_DELETED

  INSTITUTION_VERIFICATION_SUBMITTED
  INSTITUTION_VERIFICATION_APPROVED
  INSTITUTION_VERIFICATION_REJECTED

  INSTITUTION_ADDRESS_UPDATED

  INSTITUTION_LOGO_UPDATED

  INVITATION_SENT
  INVITATIONS_BULK_SENT

  GROUP_LEADER_REQUEST_SUBMITTED
  GROUP_LEADER_REQUEST_APPROVED
  GROUP_LEADER_REQUEST_REJECTED
}

enum NotificationSeverity {
  INFO
  HIGH
  CRITICAL
}

enum NotificationStatus {
  UNREAD
  READ
}

enum DocumentTemplateType {
  SRS
  SDD
  REPORT
  OTHER
}

model Milestone {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  title       String          @db.VarChar(255)
  description String?
  dueDate     DateTime        @map("due_date")
  status      MilestoneStatus @default(PENDING)
  submittedAt DateTime?       @map("submitted_at")
  feedback    String?

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("milestones")
}

model MilestoneTemplate {
  id           String   @id @default(uuid())
  tenantId     String
  departmentId String
  name         String   @db.VarChar(255)
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String?  @map("created_by")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant                     @relation(fields: [tenantId], references: [id])
  department Department                 @relation(fields: [departmentId], references: [id])
  createdBy  User?                      @relation("MilestoneTemplateCreatedBy", fields: [createdById], references: [id])
  milestones MilestoneTemplateMilestone[]
  projects   Project[]

  @@index([tenantId])
  @@index([departmentId])
  @@index([isActive])
  @@index([createdAt])
  @@map("milestone_templates")
}

model MilestoneTemplateMilestone {
  id                  String  @id @default(uuid())
  templateId           String  @map("template_id")
  sequence             Int
  title                String  @db.VarChar(255)
  description          String?
  defaultDurationDays  Int     @map("default_duration_days")
  hasDeliverable       Boolean @default(false) @map("has_deliverable")
  requiredDocuments    Json?   @map("required_documents")
  isRequired           Boolean @default(true) @map("is_required")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  template MilestoneTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, sequence])
  @@index([templateId])
  @@index([sequence])
  @@map("milestone_template_milestones")
}

// ========================
// ADVISOR MANAGEMENT
// ========================
model Advisor {
  id           String @id @default(uuid())
  userId       String @unique
  departmentId String
  loadLimit    Int    @default(5) // Maximum projects an advisor can handle
  currentLoad  Int    @default(0) // Current number of active projects

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@index([userId])
  @@index([departmentId])
  @@index([loadLimit])
  @@index([currentLoad])
  @@map("advisors")
}

model Notification {
  id             String                 @id @default(uuid())
  tenantId       String
  userId         String
  eventType      NotificationEventType
  severity       NotificationSeverity
  title          String
  message        String
  metadata       Json? // Safe metadata like ipHash, deviceFingerprintHash, etc.
  status         NotificationStatus     @default(UNREAD)
  readAt         DateTime?              @map("read_at")
  idempotencyKey String                 @unique
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, status])
  @@index([createdAt])
  @@map("notifications")
}

model PushSubscription {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String
  endpoint       String   @unique
  p256dh         String
  auth           String
  expirationTime BigInt?  // DOMTimeStamp (ms) from browser PushSubscription
  userAgent      String?  @db.VarChar(512)
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@index([lastUsedAt])
  @@map("push_subscriptions")
}

model DepartmentDocumentTemplate {
  id           String              @id @default(uuid())
  tenantId     String
  departmentId String
  type         DocumentTemplateType @default(OTHER)
  title        String              @db.VarChar(255)
  description  String?
  isActive     Boolean             @default(true) @map("is_active")
  createdById  String?             @map("created_by")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  createdBy  User?      @relation("DepartmentDocumentTemplateCreatedBy", fields: [createdById], references: [id])
  files      DepartmentDocumentTemplateFile[]

  @@index([tenantId])
  @@index([departmentId])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
  @@map("department_document_templates")
}

model DepartmentDocumentTemplateFile {
  id           String  @id @default(uuid())
  templateId   String  @map("template_id")

  fileName     String  @map("file_name")
  mimeType     String  @map("mime_type")
  sizeBytes    Int     @map("size_bytes")
  fileUrl      String  @map("file_url")
  filePublicId String  @map("file_public_id")
  resourceType String  @default("raw") @map("resource_type") @db.VarChar(20)

  uploadedById String? @map("uploaded_by")

  // Auditing
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  template   DepartmentDocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  uploadedBy User?                     @relation("DepartmentDocumentTemplateFileUploadedBy", fields: [uploadedById], references: [id])

  @@index([templateId])
  @@index([uploadedById])
  @@map("department_document_template_files")
}
